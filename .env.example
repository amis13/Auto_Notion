# ============================================================
# Notion
# ============================================================
# Token de la integración interna (https://www.notion.so/my-integrations)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Proveedor LLM por defecto (se puede cambiar por ejecución con --proveedor)
#   gemini      → API de Google AI Studio (necesita GEMINI_API_KEY)
#   gemini-cli  → tu cuenta de Google vía Gemini CLI (gratis, sin API key)
#   codex       → tu cuenta de ChatGPT vía Codex CLI (cuota de tu plan, sin API key)
#   claude      → tu cuenta de Claude vía Claude Code CLI (cuota de tu plan, sin API key)
#   openrouter  → API de pago por uso (necesita OPENROUTER_API_KEY)
#   lmstudio    → tu servidor local de LMStudio (gratis, no requiere API key)
# ============================================================
LLM_PROVIDER=gemini

# ============================================================
# gemini — API key de Google AI Studio (https://aistudio.google.com/apikey)
# ============================================================
GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXX

# Modelos (lista completa: python main.py --listar-modelos --proveedor gemini)
#   Con API key GRATUITA (los Pro y flash 3.x tienen límite 0):
#     gemini-2.5-flash        → el mejor gratuito (~20 peticiones/día)
#     gemini-2.5-flash-lite   → más flojo pero con cuota diaria aparte
#   Con facturación activada:
#     gemini-3.1-pro-preview  → el Pro más potente
#     gemini-3.5-flash | gemini-3-pro-preview | gemini-2.5-pro | gemini-pro-latest
GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# gemini-cli — requiere: npm i -g @google/gemini-cli y «gemini» → Login with Google
# Cuota gratis con cuenta personal: ~60 peticiones/min, ~1000/día
# ============================================================
# Modelos:
#   (vacío)            → el del CLI por defecto: Pro con fallback automático (recomendado)
#   gemini-2.5-pro
#   gemini-2.5-flash
GEMINI_CLI_MODEL=

# ============================================================
# codex — requiere: npm i -g @openai/codex y «codex login» con tu cuenta de ChatGPT
# El consumo sale de la cuota de tu plan (Plus/Pro)
# ============================================================
# Modelos:
#   (vacío)         → el del CLI por defecto (recomendado)
#   gpt-5.4         | gpt-5.5          → generalistas (mejores para redactar)
#   gpt-5.4-codex   | gpt-5.5-codex    → afinados para código
#   gpt-5.4-mini    → más rápido y barato en cuota
CODEX_MODEL=

# ============================================================
# claude — requiere Claude Code instalado y sesión iniciada (claude → /login)
# El consumo sale de la cuota de tu plan de Claude (Pro/Max)
# ============================================================
# Modelos:
#   (vacío)  → el de tu plan por defecto (recomendado)
#   sonnet | opus | haiku   → alias del más reciente de cada familia
#   también nombres completos, ej. claude-sonnet-5, claude-opus-4-8
CLAUDE_MODEL=

# ============================================================
# openrouter — https://openrouter.ai/settings/keys (pago por uso)
# ============================================================
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxx

# Modelos (lista completa: python main.py --listar-modelos --proveedor openrouter)
# Vale CUALQUIER modelo de OpenRouter (formato vendedor/modelo); los GPT actuales:
#   openai/gpt-5.5        → el mejor, más caro
#   openai/gpt-5.4        → muy bueno, algo más barato
#   openai/gpt-5.4-mini   → económico
#   openai/gpt-5.5-pro | openai/gpt-5.4-pro → máxima calidad, caros
# También p. ej.: anthropic/claude-*, google/gemini-*, deepseek/deepseek-*
OPENROUTER_MODEL=openai/gpt-5.5

# ============================================================
# lmstudio — modelos locales
# ============================================================
# Por defecto apunta a http://localhost:1234/v1
LMSTUDIO_API_BASE=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
# auto = no añade control; off = añade /no_think; on = añade /think.
# Útil para modelos Qwen3/Qwen3.5 en LM Studio, donde el reasoning puede gastar muchos tokens.
LMSTUDIO_THINK=auto
# native/max = carga el modelo con su max_context_length nativo según LM Studio.
# loaded = respeta la carga actual. También puedes fijar un número, ej. 32768.
# Si native no cabe en VRAM/RAM, usa un número estable menor.
LMSTUDIO_CONTEXT_LENGTH=native
# Límite opcional de salida para /v1/chat/completions. Vacío = default de LM Studio.
LMSTUDIO_MAX_TOKENS=
# Solo si activaste autenticación/API token en LM Studio.
LMSTUDIO_API_TOKEN=
